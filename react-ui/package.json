  "devDependencies": {
    "@types/react":         "^18.2.0",
    "@types/react-dom":     "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript":           "^5.3.0",
    "vite":                 "^5.1.0",
