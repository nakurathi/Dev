    "react-redux":         "^9.1.0",
    "@tanstack/react-query": "^5.20.0",
    "axios":               "^1.6.0",
    "date-fns":            "^3.3.0",
    "react-hook-form":     "^7.50.0",
    "@hookform/resolvers":  "^3.3.0",
    "zod":                  "^3.22.0",
    "recharts":             "^2.12.0",
